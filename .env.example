# ═══════════════════════════════════════════════════════════
# RELISH MARKET INTELLIGENCE — Environment Variables
# Copy to .env and fill in your keys
# ═══════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────
# Anthropic Claude API (powers AI research tabs)
ANTHROPIC_API_KEY=sk-ant-...

# ── SUPABASE (for data persistence & auth) ───────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── OPTIONAL: Trade Data Sources ─────────────────────────
# UN Comtrade Premium (free signup at comtradedeveloper.un.org)
COMTRADE_API_KEY=

# Volza — shipment-level buyer/supplier data ($1,500/yr)
VOLZA_API_KEY=

# Zauba/Seair — Indian customs data (Rs.5-15K/mo)
ZAUBA_API_KEY=

# DGFT — free, no key needed (scraped)

# OEC — Economic Complexity Observatory
OEC_API_KEY=

# ── OPTIONAL: Pricing Sources ────────────────────────────
# ChemAnalyst — weekly chemical pricing (free tier available)
CHEMANALYST_API_KEY=

# ECHEMI — daily China chemical prices
ECHEMI_API_KEY=

# Intratec — free, no key needed (~1yr lag)

# ── OPTIONAL: Marketplaces ───────────────────────────────
# Alibaba Open Platform
ALIBABA_API_KEY=

# IndiaMART IndiaMESH API
INDIAMART_API_KEY=

# ── SERVER ───────────────────────────────────────────────
API_PORT=3001
